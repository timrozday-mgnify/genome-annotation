nextflow_pipeline {
    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"

    test("mini genome - default annotation") {
        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def all_files = getAllFilesFromDir(
                "$outputDir", relative: true, includeDir: false,
                ignore: ['pipeline_info/**']
            ).sort()
            def binary_exts = ['.gz', '.RDS', '.dmnd'] as Set
            def text_files = all_files.findAll { f -> binary_exts.every { ext -> !f.endsWith(ext) } }

            assertAll(
                { assert workflow.success },

                // 1. Directory structure — all file and folder names relative to outdir
                { assert snapshot(
                    getAllFilesFromDir("$outputDir", relative: true, includeDir: true,
                        ignore: ['pipeline_info/**']).sort()
                ).match("directory_structure") },

                // 2. File sizes — all files (for .gz this is the compressed size)
                { assert snapshot(
                    all_files.collect { f -> [f, path("$outputDir/$f").size()] }
                ).match("file_sizes") },

                // 3. Line counts — text files only (.gz excluded; binary content)
                { assert snapshot(
                    text_files.collect { f ->
                        [f, path("$outputDir/$f").readLines().size()]
                    }
                ).match("line_counts") },

                // 4. MD5 checksums — text files only (.gz md5 varies with gzip timestamp)
                { assert snapshot(
                    text_files.collect { f ->
                        [f, path("$outputDir/$f").md5]
                    }
                ).match("file_md5s") }
            )
        }
    }
}
