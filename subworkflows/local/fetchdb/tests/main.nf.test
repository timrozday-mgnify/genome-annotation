nextflow_workflow {
    name "Test Subworkflow FETCHDB"
    script "../main.nf"
    workflow "FETCHDB"
    config "./nextflow.config"

    tag "subworkflows"
    tag "subworkflows_fetchdb"

    test("local path passthrough") {
        when {
            params { force_download_dbs = false }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        id: 'mini_genome',
                        local_path: "${projectDir}/tests/testdata/mini_genome.fa",
                        remote_path: false,
                        files: [:],
                        base_dir: 'mini_genome'
                    ]
                )
                input[1] = ""
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.dbs.size() == 1 },
                { assert workflow.out.dbs.get(0).get(1).toString().endsWith("mini_genome.fa") }
            )
        }
    }

    test("download when no cache") {
        when {
            params { force_download_dbs = false }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        id: 'mini_genome',
                        local_path: false,
                        remote_path: "${projectDir}/tests/testdata/mini_genome.fa",
                        files: [:],
                        base_dir: 'mini_genome'
                    ]
                )
                input[1] = ""
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.dbs.size() == 1 }
            )
        }
    }

    test("cache hit skips download") {
        // Use testdata dir as cache_path; mini_genome.fa is the cached item (id matches filename)
        when {
            params { force_download_dbs = false }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        id: 'mini_genome.fa',
                        local_path: false,
                        remote_path: "${projectDir}/tests/testdata/mini_genome.fa",
                        files: [:],
                        base_dir: 'mini_genome'
                    ]
                )
                input[1] = "${projectDir}/tests/testdata"
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert workflow.out.dbs.size() == 1 },
                { assert workflow.out.dbs.get(0).get(1).toString().endsWith("mini_genome.fa") }
            )
        }
    }
}
