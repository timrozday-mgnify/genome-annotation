nextflow_process {
    name "Test Process CONCATENATE"
    script "../main.nf"
    process "CONCATENATE"

    tag "modules"
    tag "concatenate"

    test("two fasta files - concatenated output") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    "test_concatenated.fa",
                    [
                        file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true),
                        file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                    ]
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.concatenated_file.size() == 1 },
                {
                    def expected_lines = path("${projectDir}/tests/testdata/mini_genome.fa").readLines().size() * 2
                    assert path(process.out.concatenated_file.get(0).get(1)).readLines().size() == expected_lines
                }
            )
        }
    }

    test("two fasta files - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    "test_concatenated.fa",
                    [
                        file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true),
                        file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                    ]
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.concatenated_file.size() == 1 }
            )
        }
    }
}
