nextflow_process {
    name "Test Process CHUNKFASTX"
    config "./nextflow.config"
    script "../main.nf"
    process "CHUNKFASTX"

    tag "modules"
    tag "chunkfastx"

    test("mini genome fasta - split into multiple chunks") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.chunked_reads.get(0).get(1).size() > 1 },
                { assert snapshot(
                    process.out.findAll { key, _val -> key == "versions" }
                ).match() }
            )
        }
    }

    test("mini genome fasta - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.chunked_reads.size() == 1 },
                { assert snapshot(
                    process.out.findAll { key, _val -> key == "versions" }
                ).match() }
            )
        }
    }
}
