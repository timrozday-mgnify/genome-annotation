nextflow_process {
    name "Test Process FETCHUNZIP"
    config "./nextflow.config"
    script "../main.nf"
    process "FETCHUNZIP"

    tag "modules"
    tag "fetchunzip"

    test("plain file - copy to dir") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test', files: [:], base_dir: 'test' ],
                    "test_db",
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.db_dir.size() == 1 },
                { assert path(process.out.db_dir.get(0).get(1).toString() + "/mini_genome.fa").exists() }
            )
        }
    }

    test("plain file - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id: 'test', files: [genome: 'mini_genome.fa'], base_dir: 'test' ],
                    "test_db",
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.db_dir.size() == 1 }
            )
        }
    }
}
