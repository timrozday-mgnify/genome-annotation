nextflow_process {
    name "Test Process SEQSTATS"
    script "../main.nf"
    process "SEQSTATS"

    tag "modules"
    tag "seqstats"

    test("mini genome - fasta") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                {
                    def json = new groovy.json.JsonSlurper().parseText(
                        path(process.out.stats.get(0).get(1)).text
                    )
                    assert json.seq_count > 0
                    assert json.base_count > 0
                },
                { assert snapshot(
                    process.out.findAll { key, _val -> key == "versions" }
                ).match() }
            )
        }
    }

    test("mini genome - fasta - stub") {
        options "-stub"
        when {
            process {
                """
                input[0] = [
                    [ id: 'test' ],
                    file("${projectDir}/tests/testdata/mini_genome.fa", checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(
                    process.out.findAll { key, _val -> key == "versions" }
                ).match() }
            )
        }
    }
}
